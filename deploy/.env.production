# ============================================================
# OnboardAgent 生产环境配置
# 复制到服务器 backend/.env 并修改以下值
# ============================================================

APP_NAME=OnboardAgent
DEBUG=False
DATABASE_URL=sqlite:///./edu_assistant.db

# ⚠️ 必须修改！用 python -c "import secrets; print(secrets.token_urlsafe(32))" 生成
SECRET_KEY=change-this-to-a-random-string-64-chars-minimum

# 允许访问的域名（逗号分隔，必须包含实际域名和 IP）
# 格式: https://your-domain.com,https://www.your-domain.com,http://your-server-ip
CORS_ORIGINS=https://your-domain.com,http://your-server-ip

# LLM 选择: deepseek | siliconflow | zhipu
LLM_PROVIDER=deepseek

# DeepSeek（推荐，注册送 500 万 tokens: https://platform.deepseek.com）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 硅基流动（备选）
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen3.5-397B

# 向量模型（本地运行，首次部署时自动下载）
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# 运行时数据目录（默认自动创建）
# UPLOAD_DIR=./data/uploads
# CHROMA_PERSIST_DIR=./data/chroma_db
