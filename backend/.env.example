APP_NAME=OnboardAgent
DEBUG=True
DATABASE_URL=sqlite:///./edu_assistant.db

# Runtime data dirs. Defaults are backend/data/uploads and backend/data/chroma_db.
# UPLOAD_DIR=./data/uploads
# CHROMA_PERSIST_DIR=./data/chroma_db

# deepseek | siliconflow
LLM_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# SiliconFlow（可选备用 LLM；Embedding 不使用 SiliconFlow）
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen3.5-397B

# Embedding 配置（上传向量化、知识库检索统一使用本地 BGE 小模型）
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
