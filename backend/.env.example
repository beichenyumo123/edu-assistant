APP_NAME=EduAssistant
DEBUG=True
DATABASE_URL=sqlite:///./edu_assistant.db

# deepseek | siliconflow
LLM_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
